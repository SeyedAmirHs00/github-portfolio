---
interface Props {
  title: string;
  description: string;
  href: string;
}

const {
  title,
  description,
  href,
} = Astro.props;
---

<a
  href={href}
  class="block rounded-xl border border-zinc-800 p-6 hover:border-zinc-600"
>

<h2 class="text-2xl font-semibold">
    {title}
</h2>

<p class="mt-2 text-zinc-400">
    {description}
</p>

</a>