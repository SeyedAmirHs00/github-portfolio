---
import { site } from "../data/site";
import { withBase } from "../lib/paths";

const links = [
  { href: withBase(), label: "Home" },
  { href: withBase("about"), label: "About" },
  { href: withBase("education"), label: "Education" },
  { href: withBase("skills"), label: "Skills" },
  { href: withBase("timeline"), label: "Timeline" },
  { href: withBase("blog"), label: "Blog" },
  { href: withBase("contact"), label: "Contact" },
];
---

<header class="border-b border-zinc-800">
  <nav class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-6 py-4">
    <a href={withBase()} class="text-xl font-bold">
      {site.shortName}
    </a>

    <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-zinc-300">
      {
        links.map((link) => (
          <a href={link.href} class="hover:text-white">
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
