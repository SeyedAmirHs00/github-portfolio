---
import { site } from "../data/site";

const base = import.meta.env.BASE_URL;

const links = [
  { href: base, label: "Home" },
  { href: `${base}about`, label: "About" },
  { href: `${base}education`, label: "Education" },
  { href: `${base}skills`, label: "Skills" },
  { href: `${base}timeline`, label: "Timeline" },
  { href: `${base}blog`, label: "Blog" },
  { href: `${base}contact`, label: "Contact" },
];
---

<header class="border-b border-zinc-800">
  <nav class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-6 py-4">
    <a href={base} class="text-xl font-bold">
      {site.shortName}
    </a>

    <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-zinc-300">
      {
        links.map((link) => (
          <a href={link.href} class="hover:text-white">
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
