---
import Layout from "../layouts/Layout.astro";
import { education } from "../data/education";
import { site } from "../data/site";
---

<Layout title="Education" description={`Education — ${site.name}`}>
  <article class="max-w-3xl">
    <h1 class="text-4xl font-bold tracking-tight">Education</h1>

    <section class="mt-10">
      <h2 class="text-2xl font-semibold">{education.degree}</h2>
      <p class="mt-2 text-lg text-zinc-300">{education.institution}</p>
      <p class="mt-1 text-zinc-400">{education.period}</p>
      <p class="text-zinc-400">{education.location}</p>
      <p class="mt-4 text-zinc-300">
        <span class="text-zinc-500">GPA</span>
        {" · "}
        {education.gpa}
      </p>
    </section>

    <section class="mt-12">
      <h3 class="text-xl font-semibold">Honors</h3>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-zinc-300">
        {education.honors.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="mt-12">
      <h3 class="text-xl font-semibold">Awards & Achievements</h3>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-zinc-300">
        {education.awards.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="mt-12">
      <h3 class="text-xl font-semibold">Relevant Coursework</h3>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {
          education.coursework.map((course) => (
            <li class="border-b border-zinc-800 py-2 text-zinc-300">{course}</li>
          ))
        }
      </ul>
    </section>
  </article>
</Layout>
